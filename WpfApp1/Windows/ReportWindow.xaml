<Window x:Class="AutoDealerExam.Windows.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Raport sumar comenzi"
        Height="560" Width="1180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F4F6">

    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="CardValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="210"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#111827"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="48"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="14" Margin="10">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Antet -->
            <DockPanel Grid.Row="0" LastChildFill="False">
                <TextBlock Text="Raport sumar comenzi"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           VerticalAlignment="Center"/>

                <Button Content="✕"
                        Width="32"
                        Height="32"
                        DockPanel.Dock="Right"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        FontSize="18"
                        Cursor="Hand"
                        Click="BtnInchide_Click"/>
            </DockPanel>

            <!-- Carduri statistice -->
            <UniformGrid Grid.Row="2" Columns="4">
                <!-- Total automobile -->
                <Border Style="{StaticResource CardBorderStyle}"
                        Background="#EAF1FF"
                        BorderBrush="#BFD4FF">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="40" Height="40"
                                Background="#CFE0FF"
                                CornerRadius="10"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                            <TextBlock Text="🚗"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Total automobile" Style="{StaticResource CardTitleStyle}"/>
                            <TextBlock x:Name="txtTotalAutomobile" Text="0" Style="{StaticResource CardValueStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Total comenzi -->
                <Border Style="{StaticResource CardBorderStyle}"
                        Background="#EAF9EF"
                        BorderBrush="#B9E8C8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="40" Height="40"
                                Background="#C8F0D3"
                                CornerRadius="10"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                            <TextBlock Text="🛒"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Total comenzi" Style="{StaticResource CardTitleStyle}"/>
                            <TextBlock x:Name="txtTotalComenzi" Text="0" Style="{StaticResource CardValueStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Valoare totală -->
                <Border Style="{StaticResource CardBorderStyle}"
                        Background="#F3EAFF"
                        BorderBrush="#DCC3FF">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="40" Height="40"
                                Background="#E3D0FF"
                                CornerRadius="10"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                            <TextBlock Text="$"
                                       FontSize="24"
                                       Foreground="#7C3AED"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Valoare totală" Style="{StaticResource CardTitleStyle}"/>
                            <TextBlock x:Name="txtValoareTotala" Text="0" Style="{StaticResource CardValueStyle}"/>
                            <TextBlock Text="EUR"
                                       FontSize="13"
                                       Foreground="#6B7280"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Cel mai comandat -->
                <Border Style="{StaticResource CardBorderStyle}"
                        Margin="0"
                        Background="#FFF1E8"
                        BorderBrush="#FFD3B5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="40" Height="40"
                                Background="#FFDDBF"
                                CornerRadius="10"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                            <TextBlock Text="↗"
                                       FontSize="22"
                                       Foreground="#EA580C"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Cel mai comandat" Style="{StaticResource CardTitleStyle}"/>
                            <TextBlock x:Name="txtCelMaiComandat"
                                       Text="—"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- Titlu secțiune -->
            <TextBlock Grid.Row="4"
                       Text="Raport pe clienți"
                       Style="{StaticResource SectionTitleStyle}"/>

            <!-- Tabel -->
            <Border Grid.Row="5"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="12">
                <DataGrid x:Name="dgRaport"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          BorderThickness="0"
                          Background="White"
                          AlternatingRowBackground="#FAFAFA">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Client"
                                            Binding="{Binding NumeClient}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Număr comenzi"
                                            Binding="{Binding NumarComenzi}"
                                            Width="200"/>
                        <DataGridTextColumn Header="Valoare totală (EUR)"
                                            Binding="{Binding ValoareTotalaFormatata}"
                                            Width="240"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Linie -->
            <Border Grid.Row="7"
                    Height="1"
                    Background="#E5E7EB"
                    Margin="0,0,0,16"/>

            <!-- Butoane -->
            <DockPanel Grid.Row="8" LastChildFill="False">
                <Button Content="Închide"
                        Style="{StaticResource SecondaryButtonStyle}"
                        DockPanel.Dock="Right"
                        Margin="0,0,12,0"
                        Click="BtnInchide_Click"/>

                <Button Style="{StaticResource PrimaryButtonStyle}"
                        DockPanel.Dock="Right"
                        Click="BtnExportaTxt_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⇩" Margin="0,0,8,0" FontSize="16"/>
                        <TextBlock Text="Exportă raport (TXT)"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        DockPanel.Dock="Right"
                        Click="BtnExportaPDF_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⇩" Margin="0,0,8,0" FontSize="16"/>
                        <TextBlock Text="Exportă raport (PDE)"/>
                    </StackPanel>
                </Button>
            </DockPanel>
        </Grid>
    </Border>
</Window>