<Window x:Class="AutoDealerExam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoDealer - Magazin online de automobile"
        Height="760" Width="1250"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F5">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#1F4E79" CornerRadius="12" Padding="16" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Magazin online de automobile"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Image Source="/Images/Dealer03.jpg"
                       Height="100"
                       Margin="120,8,0,0"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" FontSize="14">
            <!-- TAB AUTOMOBILE -->
            <TabItem Header="Automobile">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Formular automobil"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="Marca"/>
                                <TextBox x:Name="txtMarca" Height="30" Margin="0,4,0,10"/>

                                <TextBlock Text="Model"/>
                                <TextBox x:Name="txtModel" Height="30" Margin="0,4,0,10"/>

                                <TextBlock Text="An fabricație"/>
                                <TextBox x:Name="txtAnFabricatie" Height="30" Margin="0,4,0,10"/>

                                <TextBlock Text="Preț"/>
                                <TextBox x:Name="txtPret" Height="30" Margin="0,4,0,10"/>

                                <TextBlock Text="Tip combustibil"/>
                                <ComboBox x:Name="cmbTipCombustibil" Height="30" Margin="0,4,0,10"/>

                                <TextBlock Text="Transmisie"/>
                                <ComboBox x:Name="cmbTransmisie" Height="30" Margin="0,4,0,10"/>

                                <TextBlock Text="Stoc"/>
                                <TextBox x:Name="txtStoc" Height="30" Margin="0,4,0,10"/>

                                <WrapPanel Margin="0,10,0,0">
                                    <Button Content="Salvează"
                                            Width="94"
                                            Height="35"
                                            Margin="0,0,8,0"
                                            Click="btnSalveazaAutomobil_Click"/>
                                    <Button Content="Șterge"
                                            Width="95"
                                            Height="35"
                                            Margin="0,0,8,0"
                                            Click="btnStergeAutomobil_Click"/>
                                    <Button Content="Golește"
                                            Width="94"
                                            Height="35"
                                            Click="btnGolesteAutomobil_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="12">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                <TextBlock Text="Căutare și filtrare"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10"/>

                                <WrapPanel>
                                    <TextBox x:Name="txtCautaAuto"
                                             Width="180"
                                             Height="30"
                                             Margin="0,0,8,0"/>

                                    <ComboBox x:Name="cmbFiltruCombustibil"
                                              Width="130"
                                              Height="30"
                                              Margin="0,0,8,0"/>

                                    <TextBox x:Name="txtAnMinim"
                                             Width="90"
                                             Height="30"
                                             Margin="0,0,8,0"/>

                                    <TextBox x:Name="txtPretMaxim"
                                             Width="100"
                                             Height="30"
                                             Margin="0,0,8,0"/>

                                    <Button Content="Filtrează"
                                            Width="100"
                                            Height="30"
                                            Margin="0,0,8,0"
                                            Click="btnFiltreazaAutomobile_Click"/>

                                    <Button Content="Resetează"
                                            Width="100"
                                            Height="30"
                                            Click="btnReseteazaAutomobile_Click"/>
                                </WrapPanel>
                            </StackPanel>

                            <DataGrid x:Name="dgAutomobile"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionChanged="dgAutomobile_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding IdAutomobil}" Width="50"/>
                                    <DataGridTextColumn Header="Marca" Binding="{Binding Marca}" Width="120"/>
                                    <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="120"/>
                                    <DataGridTextColumn Header="An" Binding="{Binding AnFabricatie}" Width="80"/>
                                    <DataGridTextColumn Header="Preț" Binding="{Binding Pret}" Width="100"/>
                                    <DataGridTextColumn Header="Combustibil" Binding="{Binding TipCombustibil}" Width="120"/>
                                    <DataGridTextColumn Header="Transmisie" Binding="{Binding Transmisie}" Width="110"/>
                                    <DataGridTextColumn Header="Stoc" Binding="{Binding Stoc}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TAB CLIENȚI -->
            <TabItem Header="Clienți">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Formular client"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="Nume"/>
                            <TextBox x:Name="txtNume" Height="30" Margin="0,4,0,10"/>

                            <TextBlock Text="Prenume"/>
                            <TextBox x:Name="txtPrenume" Height="30" Margin="0,4,0,10"/>

                            <TextBlock Text="Telefon"/>
                            <TextBox x:Name="txtTelefon" Height="30" Margin="0,4,0,10"/>

                            <TextBlock Text="Email"/>
                            <TextBox x:Name="txtEmail" Height="30" Margin="0,4,0,10"/>

                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Salvează"
                                        Width="100"
                                        Height="35"
                                        Margin="0,0,8,0"
                                        Click="btnSalveazaClient_Click"/>
                                <Button Content="Șterge"
                                        Width="100"
                                        Height="35"
                                        Margin="0,0,8,0"
                                        Click="btnStergeClient_Click"/>
                                <Button Content="Golește"
                                        Width="100"
                                        Height="35"
                                        Click="btnGolesteClient_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="12">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                <TextBlock Text="Căutare clienți"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10"/>

                                <WrapPanel>
                                    <TextBox x:Name="txtCautaClient"
                                             Width="220"
                                             Height="30"
                                             Margin="0,0,8,0"/>

                                    <Button Content="Caută"
                                            Width="100"
                                            Height="30"
                                            Margin="0,0,8,0"
                                            Click="btnCautaClient_Click"/>

                                    <Button Content="Resetează"
                                            Width="100"
                                            Height="30"
                                            Click="btnReseteazaClienti_Click"/>
                                </WrapPanel>
                            </StackPanel>

                            <DataGrid x:Name="dgClienti"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionChanged="dgClienti_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding IdClient}" Width="60"/>
                                    <DataGridTextColumn Header="Nume" Binding="{Binding Nume}" Width="140"/>
                                    <DataGridTextColumn Header="Prenume" Binding="{Binding Prenume}" Width="140"/>
                                    <DataGridTextColumn Header="Telefon" Binding="{Binding Telefon}" Width="140"/>
                                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TAB COMENZI -->
            <TabItem Header="Comenzi">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Plasare comandă"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="Client"/>
                            <ComboBox x:Name="cmbClientComanda"
                                      Height="30"
                                      Margin="0,4,0,10"
                                      DisplayMemberPath="NumeComplet"
                                      SelectedValuePath="IdClient"/>

                            <TextBlock Text="Automobil"/>
                            <ComboBox x:Name="cmbAutomobilComanda"
                                      Height="30"
                                      Margin="0,4,0,10"
                                      DisplayMemberPath="DenumireCompleta"
                                      SelectedValuePath="IdAutomobil"/>

                            <TextBlock Text="Data comenzii"/>
                            <DatePicker x:Name="dpDataComanda"
                                        Height="30"
                                        Margin="0,4,0,10"/>

                            <TextBlock Text="Status comandă"/>
                            <ComboBox x:Name="cmbStatusComanda"
                                      Height="30"
                                      Margin="0,4,0,10"/>

                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Plasează"
                                        Width="100"
                                        Height="35"
                                        Margin="0,0,8,0"
                                        Click="btnPlaseazaComanda_Click"/>
                                <Button Content="Anulează"
                                        Width="100"
                                        Height="35"
                                        Margin="0,0,8,0"
                                        Click="btnAnuleazaComanda_Click"/>
                                <Button Content="Raport"
                                        Width="100"
                                        Height="35"
                                        Click="btnRaport_Click"/>
                            </WrapPanel>
                          

                            <TextBlock Text="Filtru după client"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0,20,0,10"/>

                            <ComboBox x:Name="cmbFiltruClientComenzi"
                                      Height="30"
                                      Margin="0,4,0,10"
                                      DisplayMemberPath="NumeComplet"
                                      SelectedValuePath="IdClient"/>

                            <WrapPanel>
                                <Button Content="Afișează comenzile clientului"
                                        Width="190"
                                        Height="35"
                                        Margin="0,0,8,0"
                                        Click="btnComenziClient_Click"/>
                                <Button Content="Toate comenzile"
                                        Width="118"
                                        Height="35"
                                        Click="btnToateComenzile_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="12">
                        <DataGrid x:Name="dgComenzi"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding IdComanda}" Width="60"/>
                                <DataGridTextColumn Header="Client" Binding="{Binding Client}" Width="180"/>
                                <DataGridTextColumn Header="Automobil" Binding="{Binding Automobil}" Width="220"/>
                                <DataGridTextColumn Header="Data" Binding="{Binding DataComanda}" Width="140"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusComanda}" Width="120"/>
                                <DataGridTextColumn Header="Valoare" Binding="{Binding Valoare}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>